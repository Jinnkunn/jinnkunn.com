{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Jinnkunn Workspace",
  "version": "0.1.0",
  "identifier": "com.jinnkunn.workspace",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 1280,
        "height": 900,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "center": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "acceptFirstMouse": true,
        "transparent": true
      }
    ]
  },
  "bundle": {
    "active": false
  }
}
