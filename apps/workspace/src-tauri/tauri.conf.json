{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Jinnkunn Workspace",
  "version": "0.1.2",
  "identifier": "com.jinnkunn.workspace",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 1280,
        "height": 900,
        "minWidth": 840,
        "minHeight": 640,
        "resizable": true,
        "center": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "acceptFirstMouse": true,
        "transparent": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Personal workspace shell — site-admin for jinkunchen.com",
    "longDescription": "Tauri desktop client that talks to the jinkunchen.com site-admin API. Authors posts/pages, edits routes + config, toggles deploys.",
    "macOS": {
      "minimumSystemVersion": "12.0",
      "entitlements": "./Entitlements.plist"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/Jinnkunn/jinnkunn.com/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY5QTgxRTQ1RThENDAzRjUKUldUMUE5VG9SUjZvK1ZPY3hUVk5aTERJTVovb2M0SHpkSXZRaThLTFhYU2x5Qk5GMElEVDd0S0YK",
      "dialog": false
    }
  }
}
