# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
/.open-next/
/.wrangler/

# local artifacts
/.playwright-cli/
/output/

# notion generated content/assets (synced at build time)
/content/generated/*

# Allow committing a small stub config file so middleware/imports work even
# when Notion sync hasn't run locally.
!/content/generated/protected-routes.json

# `public/notion-assets/` used to live here, but `content/generated/**`
# hardcodes `/notion-assets/<sha>.png` paths in the baked HTML — if the
# files aren't in the repo, prod 404s. Track them until the content
# pipeline moves off hard-coded paths.

# production
/build
apps/workspace/dist/
apps/workspace/src-tauri/target/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
