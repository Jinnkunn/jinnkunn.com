{
  "name": "jinnkunn.com",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "prebuild": "node scripts/prebuild.mjs",
    "build": "next build --webpack",
    "analyze": "ANALYZE=1 next build --webpack",
    "build:cf": "npm run build && node scripts/export-classic-css-assets.mjs && npx --yes -p @opennextjs/cloudflare opennextjs-cloudflare build && node scripts/export-classic-css-assets.mjs && node scripts/export-static-shell-assets.mjs",
    "vercel-build": "node scripts/prebuild.mjs && next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "test": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --test 'tests/**/*.test.mjs'",
    "check:scripts": "node scripts/check-scripts.mjs",
    "migrate:home:v3": "node scripts/migrate-home-to-sections.mjs",
    "sync:notion": "node scripts/sync-notion.mjs",
    "provision:admin": "node scripts/provision-site-admin.mjs",
    "snapshot:ui": "node scripts/ui-snapshots.mjs",
    "snapshot:search": "node scripts/search-snapshots.mjs",
    "snapshot:compare": "node scripts/ui-compare-snapshots.mjs",
    "smoke:ui": "node scripts/smoke-ui.mjs",
    "check:classic-css": "node scripts/classic-css-boundary-check.mjs",
    "check:classic-style": "node scripts/classic-style-contract.mjs",
    "check:production-style": "node scripts/production-style-regression.mjs",
    "check:staging-visual": "node scripts/production-style-regression.mjs --skip-build --candidate-origin=https://staging.jinkunchen.com --candidate-auth",
    "check:public-web": "npm run check:classic-css && npm run check:design-system && npm run check:classic-style && npm run check:production-style -- --skip-build",
    "smoke:site-admin": "node scripts/site-admin-smoke.mjs",
    "smoke:site-admin:write:staging": "node scripts/site-admin-write-smoke.mjs --env=staging --conflict=1",
    "smoke:site-admin:write:prod": "node scripts/site-admin-write-smoke.mjs --env=production --conflict=0",
    "smoke:site-admin:content": "node scripts/site-admin-content-smoke.mjs",
    "drill:rollback:staging": "node scripts/site-admin-rollback-drill.mjs --env=staging",
    "drill:rollback:prod": "node scripts/site-admin-rollback-drill.mjs --env=production",
    "deploy:cf:staging": "node scripts/deploy-cloudflare.mjs --env=staging",
    "deploy:cf:prod": "node scripts/deploy-cloudflare.mjs --env=production",
    "release:staging": "node scripts/release-cloudflare.mjs --env=staging",
    "release:prod": "node scripts/release-cloudflare.mjs --env=production",
    "release:prod:dry-run": "node scripts/release-cloudflare.mjs --env=production --dry-run",
    "verify:cf:staging": "node scripts/verify-cloudflare-deployment.mjs --env=staging",
    "verify:cf:prod": "node scripts/verify-cloudflare-deployment.mjs --env=production",
    "verify:cf:both": "node scripts/verify-cloudflare-deployment.mjs --env=both",
    "verify:staging:authenticated": "node scripts/staging-authenticated-qa.mjs",
    "smoke:prod": "node scripts/smoke-prod.mjs",
    "check:quality:prod": "node scripts/quality-prod.mjs",
    "check:cf:cutover": "node scripts/check-cloudflare-cutover.mjs",
    "check:a11y": "node scripts/a11y-check.mjs",
    "check:perf": "node scripts/perf-budget.mjs",
    "check:design-system": "node scripts/check-design-system.mjs",
    "check:workspace-ui": "node scripts/workspace-ui-smoke.mjs",
    "check:home-style": "node scripts/home-style-contract.mjs",
    "check:ui": "node scripts/check-ui.mjs",
    "workspace:tauri:dev": "cd apps/workspace && npm run tauri:dev",
    "workspace:tauri:build": "cd apps/workspace && npm run tauri:build"
  },
  "dependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "flags": "^4.0.3",
    "gray-matter": "^4.0.3",
    "katex": "^0.16.28",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "parse5": "^7.3.0",
    "prismjs": "^1.30.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-slug": "^6.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "axe-core": "^4.11.1",
    "cheerio": "^1.2.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "pixelmatch": "^7.1.0",
    "playwright-core": "^1.58.2",
    "pngjs": "^7.0.0",
    "sharp": "^0.34.5",
    "turndown": "^7.2.4",
    "typescript": "^5"
  }
}
