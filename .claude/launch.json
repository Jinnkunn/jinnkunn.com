{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3199,
      "autoPort": true
    },
    {
      "name": "prod",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start"],
      "port": 3200,
      "autoPort": true,
      "env": {
        "PORT": "3200"
      }
    },
    {
      "name": "workspace",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "apps/workspace",
      "port": 1420,
      "autoPort": true
    }
  ]
}
